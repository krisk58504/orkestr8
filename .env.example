# PMS-Build — environment template.
# Copy to .env.local and fill with DEV values only.
#
# NEVER place production credentials in any committed or build-read file.
# See SPEC.md section 6 (enforcement model): production Supabase / Resend
# secrets are held exclusively by the human operator.

# --- Supabase (DEV project) ------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres connection (migrations only, used by scripts/) ---------------
# Use the Supabase "Session pooler" connection string — it is IPv4-compatible.
# The direct db.<ref>.supabase.co host is IPv6-only and may be unreachable.
DATABASE_URL=

# --- Email / Resend (SPEC Gate 3) ------------------------------------------
# Development MUST run in test mode. Real recipients are blocked unless
# EMAIL_MODE=production, which is an operator-only production action.
RESEND_API_KEY=
EMAIL_MODE=test
APPROVED_TEST_EMAILS=

# --- AI / Anthropic Claude (SPEC Gate 2) -----------------------------------
# Phase 6 AI engine — maintenance triage uses Anthropic Claude via the
# Vercel AI SDK. The model defaults to Sonnet 4.6 (current production
# snapshot). Override ANTHROPIC_MODEL to experiment with newer revisions
# in a Preview environment without code changes.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Cron (Phase 7 — Vercel Cron entrypoint protection) --------------------
# Random 32-byte hex; sent by Vercel Cron as `Authorization: Bearer <value>`
# to /api/cron/automations. Without this set, the cron endpoint returns 500
# at runtime — fail-closed so cron cannot fire against an unconfigured prod.
# Set in Vercel project env vars (Settings → Environment Variables) for
# cron auth on Preview + Production; local .env.local can use any random
# value for manual curl testing.
CRON_SECRET=
